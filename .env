# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings


NODE_ENV=development
PORT=5000

DATABASE_URL=postgresql://postgres:128169@localhost:5432/clinically_manic_postgres?schema=public

CLIENT_URL=http://localhost:3000

BCRYPT_SALT_ROUNDS=12

ACCESS_TOKEN_SECRET=dev_access_secret_123456
REFRESH_TOKEN_SECRET=dev_refresh_secret_123456

ACCESS_TOKEN_EXPIRES_IN=1d
REFRESH_TOKEN_EXPIRES_IN=365d

RESET_PASS_UI_LINK=http://localhost:3000/reset-password

EMAIL_FROM=admin@example.com
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_PORT=587
EMAIL_HOST=smtp.gmail.com

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

COOKIE_SECRET=dev_cookie_secret_123456